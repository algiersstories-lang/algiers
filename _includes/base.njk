<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="https://algiersstories-lang.github.io/images/icon-casbah.png">
    
    <title>{{ title }} | Algiers Stories</title>
    
    <style>
        :root {
            --hist-teal: #008080;
            --med-blue: #4CB6C9;
            --terracotta: #A0522D;
            --parchment: #F5F5DC;
            --charcoal: #333333;
        }

        body {
            font-family: 'Georgia', serif;
            line-height: 1.6;
            margin: 0;
            background-color: #fdfdfd;
            color: var(--charcoal);
        }

        /* Navigation Header */
        header {
            background-color: white;
            border-bottom: 3px solid var(--hist-teal);
            padding: 10px 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 1001; /* Stays above the map */
        }

        /* Logo and Title Container */
        .brand {
            display: flex;
            align-items: center;
            text-decoration: none;
            gap: 12px;
        }

        .logo-img {
            height: 45px; /* Adjust height as needed */
            width: auto;
            object-fit: contain;
        }

        .site-title {
            color: var(--hist-teal);
            margin: 0;
            font-size: 1.5rem;
            font-weight: bold;
        }

        /* Navigation Links */
        nav ul {
            list-style: none;
            margin: 0;
            padding: 0;
            display: flex;
            gap: 20px;
        }

        nav a {
            text-decoration: none;
            color: var(--charcoal);
            font-weight: bold;
            font-size: 1rem;
            transition: color 0.3s;
        }

        nav a:hover {
            color: var(--med-blue);
        }

        /* Layout Containers */
        main {
            padding: 20px 5%;
            max-width: 1200px;
            margin: 0 auto;
        }

        footer {
            text-align: center;
            padding: 20px;
            font-size: 0.9rem;
            color: #777;
            border-top: 1px solid #eee;
            margin-top: 40px;
        }

        /* Mobile Optimization */
        @media (max-width: 600px) {
            header { flex-direction: column; gap: 10px; }
            .site-title { font-size: 1.2rem; }
        }
    </style>
</head>
<body>

    <header>
        <a href="/" class="brand">
            <img src="https://algiersstories-lang.github.io/images/log-casbah.png" alt="Algiers Stories Logo" class="logo-img">
            <h1 class="site-title">Algiers Stories</h1>
        </a>
        <nav>
            <ul>
                <li><a href="/">Home</a></li>
                <li><a href="/monuments/">Monuments</a></li>
                <li><a href="/map/">Map</a></li>
                <li><a href="/history/">History</a></li>
            </ul>
        </nav>
    </header>

    <main>
        {{ content | safe }}
    </main>

    <footer>
        <p>&copy; 2026 Algiers Stories - Safeguarding the Memory of the White City.</p>
    </footer>

</body>
</html>
