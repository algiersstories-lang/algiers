---
layout: base.njk
pagination:
  data: monuments
  size: 1
  alias: item
permalink: "monuments/{{ item.name | slugify }}/index.html"
renderData:
  title: "{{ item.name }}"
---

<style>
    .short-desc { font-style: italic; font-size: 1.3rem; color: #555; margin-bottom: 30px; }
    
    .info-grid-box {
        background: var(--hist-teal);
        color: white;
        padding: 20px;
        border-radius: 4px;
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 15px;
        margin-bottom: 40px;
    }
    .info-grid-box span { font-size: 1.05rem; }

    .interleaved-img {
        width: 100%;
        max-height: 500px;
        object-fit: cover;
        border: 10px solid white;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        margin: 30px 0;
        display: block;
    }

    .section-block {
        margin-bottom: 30px;
    }
    .section-block h2 {
        margin-top: 0;
    }

    .gallery-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 20px;
        margin-top: 20px;
        margin-bottom: 30px;
    }
    .gallery-grid img { 
        width: 100%; 
        height: 200px;
        object-fit: cover;
        border: 5px solid white; 
        box-shadow: 0 3px 6px rgba(0,0,0,0.1); 
    }

    .map-btn-container {
        text-align: center;
        background: white;
        padding: 20px;
        border: 2px dashed var(--med-blue);
        margin: 40px 0 20px 0;
    }
    .map-btn { color: var(--hist-teal); text-decoration: none; font-weight: bold; display: flex; align-items: center; justify-content: center; gap: 10px; }

    .external-btn {
        display: block;
        text-align: center;
        background: var(--med-blue);
        color: white;
        padding: 15px;
        text-decoration: none;
        border-radius: 4px;
        font-weight: bold;
        margin: 20px 0 50px 0;
    }
</style>

<h1>{{ item.name }}</h1>

<div class="info-grid-box">
    <span><strong>Category:</strong> {{ item.category if item.category else 'N/A' }}</span>
    <span><strong>Period:</strong> {{ item.period if item.period else 'N/A' }}</span>
    <span><strong>Dynasty:</strong> {{ item.dynasty if item.dynasty else 'N/A' }}</span>
    <span><strong>Status:</strong> {{ item.status if item.status else 'N/A' }}</span>
</div>

{# Convert the comma-separated cell into a clean array list #}
{% set imageList = item.images.split(',') if item.images else [] %}

<div class="short-desc">{{ item.description }}</div>

{% if imageList[0] %}
<img src="{{ imageList[0] | trim }}" class="interleaved-img" alt="{{ item.name }}">
{% endif %}

<div class="section-block long-description">
    <p>{{ item.long_description }}</p>
</div>

{% if imageList[1] %}
<img src="{{ imageList[1] | trim }}" class="interleaved-img" alt="{{ item.name }} secondary view">
{% endif %}

{% if item.geography %}
<div class="section-block">
    <h2>Geography</h2>
    <p>{{ item.geography }}</p>
</div>
{% endif %}

{% if imageList[2] %}
<img src="{{ imageList[2] | trim }}" class="interleaved-img" alt="{{ item.name }} geographic view">
{% endif %}

{% if item.history %}
<div class="section-block">
    <h2>History</h2>
    <p>{{ item.history }}</p>
</div>
{% endif %}

{% if imageList[3] %}
<img src="{{ imageList[3] | trim }}" class="interleaved-img" alt="{{ item.name }} historical archive view">
{% endif %}

{% if item.architecture %}
<div class="section-block">
    <h2>Architecture</h2>
    <p>{{ item.architecture }}</p>
</div>
{% endif %}

<div class="map-btn-container">
    <a href="https://www.google.com/maps/search/?api=1&query={{ item.lat }},{{ item.lon }}" target="_blank" class="map-btn">
        Find direction to {{ item.name }} on Google Map
        <img src="https://algiersstories-lang.github.io/images/map-icon.png" alt="Map Icon" style="width: 50px;">
    </a>
</div>

{% if item.external_link %}
<a href="{{ item.external_link }}" target="_blank" class="external-btn">Read more ...</a>
{% endif %}

{% if imageList.length > 4 %}
<h2>More Photography</h2>
<div class="gallery-grid">
    {% for photoUrl in imageList %}
        {# Skip the first 4 images since they are displayed sequentially above #}
        {% if loop.index0 >= 4 %}
            <img src="{{ photoUrl | trim }}" alt="{{ item.name }} additional image">
        {% endif %}
    {% endfor %}
</div>
{% endif %}
