---
layout: base.njk
pagination:
  data: monuments
  size: 1
  alias: item
permalink: "monuments/{{ item.name | slugify }}/index.html"
renderData:
  title: "{{ item.name }}"
---

<style>
    .short-desc { font-style: italic; font-size: 1.3rem; color: #555; margin-bottom: 30px; }
    
    .history-box {
        background: var(--hist-teal);
        color: white;
        padding: 20px;
        border-radius: 4px;
        display: flex;
        justify-content: space-around;
        margin-bottom: 40px;
    }

    .main-img {
        width: 100%;
        border: 10px solid white;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        margin-bottom: 40px;
    }

    .gallery-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 30px;
    }
    .gallery-grid img { width: 100%; border: 5px solid white; box-shadow: 0 3px 6px rgba(0,0,0,0.1); }

    .map-btn-container {
        text-align: center;
        background: white;
        padding: 20px;
        border: 2px dashed var(--med-blue);
        margin: 30px 0;
    }
    .map-btn { color: var(--hist-teal); text-decoration: none; font-weight: bold; display: flex; align-items: center; justify-content: center; gap: 10px; }

    .external-btn {
        display: block;
        text-align: center;
        background: var(--med-blue);
        color: white;
        padding: 15px;
        text-decoration: none;
        border-radius: 4px;
        font-weight: bold;
        margin-top: 50px;
    }
</style>

<h1>{{ item.name }}</h1>

<div class="short-desc">{{ item.description }}</div>

<div class="history-box">
    <span><strong>Dynasty:</strong> {{ item.dynasty }}</span>
    <span><strong>Period:</strong> {{ item.period }}</span>
</div>

{# Create a reusable array by splitting the comma-separated string #}
{% set imageList = item.images.split(',') if item.images else [] %}

{% if imageList.length > 0 %}
<img src="{{ imageList[0] | trim }}" class="main-img" alt="{{ item.name }}">
{% endif %}

<div class="long-description">
    <p>{{ item.long_description }}</p>
</div>

{% if imageList.length > 1 %}
<h2>Photography</h2>
<div class="gallery-grid">
    {% for photoUrl in imageList %}
        {% if not loop.first %}
            <img src="{{ photoUrl | trim }}" alt="{{ item.name }} gallery image">
        {% endif %}
    {% endfor %}
</div>
{% endif %}

<div class="map-btn-container">
    <a href="https://www.google.com/maps/search/?api=1&query={{ item.lat }},{{ item.lon }}" target="_blank" class="map-btn">
        Find direction to {{ item.name }} on Google Map
        <img src="https://algiersstories-lang.github.io/images/map-icon.png" alt="Map Icon" style="width: 50px;">
    </a>
</div>

<h2>History</h2>
<p>{{ item.history }}</p>

<h2>Architecture</h2>
<p>{{ item.architecture }}</p>

{% if item.external_link %}
<a href="{{ item.external_link }}" target="_blank" class="external-btn">Read more ...</a>
{% endif %}
