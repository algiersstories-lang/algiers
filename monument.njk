---
pagination:
  data: monuments
  size: 1
  alias: item
permalink: "monuments/{{ item.name | slugify }}/index.html"
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ item.name }} | Algiers Stories</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/water.css@2/out/water.css">
</head>
<body>
    <a href="/algiers/">← Back to Home</a>
    <h1>{{ item.name }}</h1>
    
    {% if item.photo %}
    <img src="{{ item.photo }}" alt="{{ item.name }}" style="width:100%; border-radius:8px;">
    {% endif %}

    <p>{{ item.description }}</p>

    <h2>History</h2>
    <p>{{ item.history }}</p>

    <h2>Architecture</h2>
    <p>{{ item.architecture }}</p>

    {% if item.image1 or item.image2 %}
    <h3>Gallery</h3>
    <div style="display: flex; gap: 10px;">
        {% if item.image1 %}<img src="{{ item.image1 }}" style="width:48%;">{% endif %}
        {% if item.image2 %}<img src="{{ item.image2 }}" style="width:48%;">{% endif %}
    </div>
    {% endif %}

    <div style="background:#f0f0f0; padding:20px; margin-top:20px; border-radius:8px; color:#333;">
        <p><strong>Dynasty:</strong> {{ item.dynasty }} | <strong>Period:</strong> {{ item.period }}</p>
        <p><strong>Location:</strong> {{ item.lat }}, {{ item.lon }}</p>
    </div>
</body>
</html>
