---
pagination:
  data: monuments
  size: 1
  alias: item
permalink: "monuments/{{ item.name | slugify }}/index.html"
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ item.name }} | Algiers Stories</title>
    <style>
        :root {
            --med-blue: #4CB6C9;
            --hist-teal: #006064;
            --terracotta: #A0522D;
            --parchment: #F5F5DC;
        }
        body {
            background-color: var(--parchment);
            color: #333;
            font-family: 'Georgia', serif;
            max-width: 800px;
            margin: 0 auto;
            padding: 40px 20px;
            line-height: 1.7;
        }
        .back-link { color: var(--med-blue); text-decoration: none; font-weight: bold; display: block; margin-bottom: 20px; }
        
        h1 { color: var(--hist-teal); font-size: 2.8rem; margin: 10px 0; }
        
        .description { font-style: italic; font-size: 1.2rem; color: #555; margin-bottom: 25px; }

        .history-box {
            background: var(--hist-teal);
            color: white;
            padding: 20px;
            border-radius: 4px;
            margin: 20px 0;
            display: flex;
            justify-content: space-around;
        }

        .main-photo {
            width: 100%;
            height: auto;
            border: 8px solid white;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            margin: 30px 0;
        }

        .content-section {
            background: #fff;
            padding: 30px;
            border-radius: 8px;
            border-top: 4px solid var(--terracotta);
            margin-top: 20px;
        }

        h2 { 
            color: var(--terracotta); 
            border-bottom: 1px solid #eee;
            padding-bottom: 10px;
            margin-top: 30px;
        }

        .external-link {
            display: inline-block;
            margin-top: 40px;
            padding: 10px 20px;
            background-color: var(--med-blue);
            color: white;
            text-decoration: none;
            border-radius: 4px;
            font-weight: bold;
        }
        .external-link:hover { background-color: var(--hist-teal); }
        
        .gallery-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin: 20px 0;
        }
        .gallery-grid img { width: 100%; border: 4px solid white; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
    </style>
</head>
<body>

    <a href="/algiers/" class="back-link">← Back to List</a>
    
    <!-- 1. Name -->
    <h1>{{ item.name }}</h1>
    
    <!-- 2. Description -->
    <div class="description">{{ item.description }}</div>

    <!-- 3. History Box (Metadata) -->
    <div class="history-box">
        <span><strong>Dynasty:</strong> {{ item.dynasty }}</span>
        <span><strong>Period:</strong> {{ item.period }}</span>
        <span><strong>Status:</strong> {{ item.status }}</span>
    </div>

    <!-- 4. Photo -->
    {% if item.photo %}
    <img src="{{ item.photo }}" alt="{{ item.name }}" class="main-photo">
    {% endif %}

    <!-- 5. Long Description -->
    <div class="long-description">
        <p>{{ item.long_description }}</p>
    </div>

    <div class="content-section">
        <!-- 6. Photography (Gallery) -->
        {% if item.image1 or item.image2 %}
        <h2>Photography</h2>
        <div class="gallery-grid">
            {% if item.image1 %}<img src="{{ item.image1 }}" alt="Gallery 1">{% endif %}
            {% if item.image2 %}<img src="{{ item.image2 }}" alt="Gallery 2">{% endif %}
        </div>
        {% endif %}

        <!-- 7. History -->
        <h2>History</h2>
        <p>{{ item.history }}</p>
        
        <!-- 8. Architecture -->
        <h2>Architecture</h2>
        <p>{{ item.architecture }}</p>
    </div>

    <!-- 9. External Link -->
    {% if item.external_link %}
    <a href="{{ item.external_link }}" target="_blank" class="external-link">Explore Further (External Source)</a>
    {% endif %}

</body>
</html>
