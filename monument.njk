---
layout: base.njk
pagination:
  data: monuments
  size: 1
  alias: item
permalink: "monuments/{{ item.name | slugify }}/index.html"
renderData:
  title: "{{ item.name }}"
---

<style>
    .short-desc { font-style: italic; font-size: 1.3rem; color: #555; margin-bottom: 30px; }
    
    .history-box {
        background: var(--hist-teal);
        color: white;
        padding: 20px;
        border-radius: 4px;
        display: flex;
        justify-content: space-around;
        margin-bottom: 40px;
    }

    .main-img {
        width: 100%;
        border: 10px solid white;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        margin-bottom: 40px;
    }

    .gallery-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 30px;
    }
    .gallery-grid img { width: 100%; border: 5px solid white; box-shadow: 0 3px 6px rgba(0,0,0,0.1); }

    .map-btn-container {
        text-align: center;
        background: white;
        padding: 20px;
        border: 2px dashed var(--med-blue);
        margin: 30px 0;
    }
    .map-btn { color: var(--hist-teal); text-decoration: none; font-weight: bold; display: flex; align-items: center; justify-content: center; gap: 10px; }

    .external-btn {
        display: block;
        text-align: center;
        background: var(--med-blue);
        color: white;
        padding: 15px;
        text-decoration: none;
        border-radius: 4px;
        font-weight: bold;
        margin-top: 50px;
    }
</style>

<!-- 1. Name -->
<h1>{{ item.name }}</h1>

<!-- 2. Description -->
<div class="short-desc">{{ item.description }}</div>

<!-- 3. History Box -->
<div class="history-box">
    <span><strong>Dynasty:</strong> {{ item.dynasty }}</span>
    <span><strong>Period:</strong> {{ item.period }}</span>
</div>

<!-- 4. Photo -->
{% if item.photo %}
<img src="{{ item.photo }}" class="main-img" alt="{{ item.name }}">
{% endif %}

<!-- 5. Long Description -->
<div class="long-description">
    <p>{{ item.long_description }}</p>
</div>

<!-- 6. Photography -->
{% if item.image1 or item.image2 %}
<h2>Photography</h2>
<div class="gallery-grid">
    {% if item.image1 %}<img src="{{ item.image1 }}">{% endif %}
    {% if item.image2 %}<img src="{{ item.image2 }}">{% endif %}
</div>
{% endif %}

<!-- Map Link with Icon -->
<div class="map-btn-container">
    <a href="https://www.google.com/maps/search/?api=1&query={{ item.lat }},{{ item.lon }}" target="_blank" class="map-btn">
        Find direction to {{ item.name }} on Google Map
        <img src="https://algiersstories-lang.github.io/images/map-icon.png" alt="Map Icon" style="width: 30px;">
    </a>
</div>

<!-- 7. History -->
<h2>History</h2>
<p>{{ item.history }}</p>

<!-- 8. Architecture -->
<h2>Architecture</h2>
<p>{{ item.architecture }}</p>

<!-- 9. External Link -->
{% if item.external_link %}
<a href="{{ item.external_link }}" target="_blank" class="external-btn">Official Reference Source</a>
{% endif %}
