<div style="text-align: center; padding: 60px 20px;">
    <!-- Hero Header -->
    <h1 style="font-size: clamp(2.5rem, 8vw, 4rem); color: var(--hist-teal); margin-bottom: 10px;">Algiers Stories</h1>
    <p style="font-size: 1.25rem; max-width: 700px; margin: 0 auto 40px auto; color: #555; line-height: 1.6;">
        Journey through the history, architecture, and legends of the Casbah and the Mediterranean soul of the White City.
    </p>
    
    <!-- Discovery Cards -->
    <div style="display: flex; justify-content: center; gap: 25px; flex-wrap: wrap; margin-top: 20px;">
        
        <!-- Card 1: Interactive Map -->
        <a href="/algiers/map/" style="text-decoration: none; color: inherit; width: 280px;">
            <div style="background: white; padding: 30px; border-radius: 12px; border-bottom: 6px solid var(--med-blue); box-shadow: 0 10px 20px rgba(0,0,0,0.05); transition: transform 0.3s ease;" onmouseover="this.style.transform='translateY(-10px)'" onmouseout="this.style.transform='translateY(0)'">
                <span style="font-size: 3.5rem; display: block; margin-bottom: 15px;">🗺️</span>
                <h3 style="color: var(--hist-teal); margin-bottom: 10px;">Interactive Map</h3>
                <p style="color: #666; font-size: 0.95rem;">Locate historical monuments and hidden gems across the city.</p>
            </div>
        </a>

        <!-- Card 2: Heritage Archive -->
        <a href="/algiers/list/" style="text-decoration: none; color: inherit; width: 280px;">
            <div style="background: white; padding: 30px; border-radius: 12px; border-bottom: 6px solid var(--terracotta); box-shadow: 0 10px 20px rgba(0,0,0,0.05); transition: transform 0.3s ease;" onmouseover="this.style.transform='translateY(-10px)'" onmouseout="this.style.transform='translateY(0)'">
                <span style="font-size: 3.5rem; display: block; margin-bottom: 15px;">🏛️</span>
                <h3 style="color: var(--hist-teal); margin-bottom: 10px;">Heritage Archive</h3>
                <p style="color: #666; font-size: 0.95rem;">Browse the full collection of documented sites and palaces.</p>
            </div>
        </a>

        <!-- Card 3: History of Algiers (New) -->
        <a href="/algiers/history/" style="text-decoration: none; color: inherit; width: 280px;">
            <div style="background: white; padding: 30px; border-radius: 12px; border-bottom: 6px solid var(--hist-teal); box-shadow: 0 10px 20px rgba(0,0,0,0.05); transition: transform 0.3s ease;" onmouseover="this.style.transform='translateY(-10px)'" onmouseout="this.style.transform='translateY(0)'">
                <span style="font-size: 3.5rem; display: block; margin-bottom: 15px;">📜</span>
                <h3 style="color: var(--hist-teal); margin-bottom: 10px;">City History</h3>
                <p style="color: #666; font-size: 0.95rem;">Timeline of Algiers, from Icosium to the Ottoman era.</p>
            </div>
        </a>

    </div>
</div>

<!-- Bottom Story Section -->
<div style="margin-top: 40px; background: white; padding: 50px; border-radius: 15px; border: 1px solid #eee; box-shadow: inset 0 0 50px rgba(0,96,100,0.02);">
    <h2 style="color: var(--terracotta); font-variant: small-caps;">Preserving the Memory of Algiers</h2>
    <p style="font-size: 1.1rem; color: #444;">
        This project is a digital tribute to <strong>Alger la Blanche</strong>. Every stone in the Casbah tells a story of dynasties, craftsmanship, and a Mediterranean identity that has endured for centuries. By documenting these monuments, we ensure the narrative of our ancestors remains alive for the next generation.
    </p>
</div>
