<script>
  (function() {
    // 1. Get the 'key' parameter from the URL
    const urlParams = new URLSearchParams(window.location.search);
    const userKey = urlParams.get('key');

    // 2. Define your secret key
    const secretKey = "SuperSecretPassword123";

    const secureDiv = document.getElementById('secure-content');
    const fallbackDiv = document.getElementById('fallback-content');

    if (userKey === secretKey) {
      // Key matches: update page title, show admin content, hide 404
      document.title = "Admin Tools";
      secureDiv.style.display = "block";
      fallbackDiv.style.direction = "none"; 
      fallbackDiv.remove(); 
    } else {
      // Key fails: aggressively delete the admin HTML from the browser memory
      secureDiv.remove();
    }
  })();
</script>
